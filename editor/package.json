const { Command } = require('commander');

const blessed = require('blessed');

const fs = require('fs');

const path = require('path');

const hljs = require('highlight.js');

const axios = require('axios');

const program = new Command();

program

  .name('grok-edit')

  .description('CLI Text Editor for Grok CLI')

  .version('1.0.0');

program

  .command('open <file>')

  .description('Open a file in the editor')

  .action((file) => {

    openEditor(file);

  });

program

  .command('search <pattern> [dir]')

  .description('Batch search for pattern in files')

  .action((pattern, dir = '.') => {

    batchSearch(pattern, dir);

  });

program

  .command('sort <file> [key]')

  .description('Sort data in file')

  .action((file, key) => {

    sortFile(file, key);

  });

program

  .command('share <file>')

  .description('Share file with console.x.ai')

  .action((file) => {

    shareFile(file);

  });

program.parse();

function openEditor(file) {

  const screen = blessed.screen({

    smartCSR: true,

    title: 'Grok Editor'

  });

  const box = blessed.box({

    top: 0,

    left: 0,

    width: '100%',

    height: '100%',

    content: '',

    scrollable: true,

    alwaysScroll: true,

    keys: true,

    vi: true

  });

  screen.append(box);

  if (fs.existsSync(file)) {

    const content = fs.readFileSync(file, 'utf8');

    box.setContent(highlightContent(content, path.extname(file)));

  }

  box.focus();

  screen.key(['escape', 'q', 'C-c'], () => {

    return process.exit(0);

  });

  screen.key(['C-s'], () => {

    saveFile(file, box.getContent());

    box.setContent(box.getContent() + '\nSaved!');

  });

  screen.render();

}

function highlightContent(content, ext) {

  const lang = getLangFromExt(ext);

  if (lang) {

    return hljs.highlight(content, { language: lang }).value;

  }

  return content;

}

function getLangFromExt(ext) {

  const map = {

    '.js': 'javascript',

    '.py': 'python',

    '.html': 'html',

    '.css': 'css',

    // add more

  };

  return map[ext];

}

function saveFile(file, content) {

  fs.writeFileSync(file, content);

}

function batchSearch(pattern, dir) {

  // Use grep tool, but since CLI, use child_process or something

  const { execSync } = require('child_process');

  try {

    const result = execSync(`grep -r "${pattern}" ${dir}`, { encoding: 'utf8' });

    console.log(result);

  } catch (e) {

    console.log('No matches');

  }

}

function sortFile(file, key) {

  if (!fs.existsSync(file)) return;

  let content = fs.readFileSync(file, 'utf8');

  let lines = content.split('\n');

  if (key) {

    // assume CSV or JSON, simple sort

    lines.sort((a,b) => a.localeCompare(b));

  } else {

    lines.sort();

  }

  fs.writeFileSync(file, lines.join('\n'));

  console.log('Sorted');

}

function shareFile(file) {

  if (!fs.existsSync(file)) return;

  const content = fs.readFileSync(file, 'utf8');

  // placeholder for console.x.ai API

  axios.post('https://console.x.ai/upload', { file: path.basename(file), content })

    .then(() => console.log('Shared'))

    .catch(() => console.log('Failed to share'));

}

