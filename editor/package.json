<!DOCTYPE html>

<html>

<head>

  <title>Grok Editor</title>

  <script src="https://unpkg.com/monaco-editor@0.45.0/min/vs/loader.min.js"></script>

  <style>

    body { margin: 0; }

    #container { height: 100vh; }

    #toolbar { background: #f0f0f0; padding: 5px; }

  </style>

</head>

<body>

  <div id="toolbar">

    <button onclick="openFile()">Open</button>

    <button onclick="saveFile()">Save</button>

    <button onclick="batchSearch()">Batch Search</button>

    <button onclick="sortData()">Sort</button>

    <button onclick="shareProject()">Share with console.x.ai</button>

  </div>

  <div id="container"></div>

  <script>

    const fs = require('fs');

    const path = require('path');

    const { dialog } = require('electron').remote;

    const axios = require('axios');

    let editor;

    let currentFile;

    require.config({ paths: { 'vs': 'https://unpkg.com/monaco-editor@0.45.0/min/vs' } });

    require(['vs/editor/editor.main'], function() {

      editor = monaco.editor.create(document.getElementById('container'), {

        value: '// Welcome to Grok Editor',

        language: 'javascript'

      });

    });

    function openFile() {

      dialog.showOpenDialog({ properties: ['openFile'] }).then(result => {

        if (!result.canceled) {

          currentFile = result.filePaths[0];

          const content = fs.readFileSync(currentFile, 'utf8');

          const lang = getLangFromExt(path.extname(currentFile));

          editor.setValue(content);

          monaco.editor.setModelLanguage(editor.getModel(), lang);

        }

      });

    }

    function saveFile() {

      if (currentFile) {

        fs.writeFileSync(currentFile, editor.getValue());

        alert('Saved');

      } else {

        dialog.showSaveDialog({}).then(result => {

          if (!result.canceled) {

            fs.writeFileSync(result.filePath, editor.getValue());

            currentFile = result.filePath;

          }

        });

      }

    }

    function batchSearch() {

      const pattern = prompt('Enter search pattern');

      const dir = prompt('Enter directory', '.');

      // simple search

      const files = fs.readdirSync(dir);

      let results = '';

      files.forEach(file => {

        if (fs.statSync(path.join(dir, file)).isFile()) {

          const content = fs.readFileSync(path.join(dir, file), 'utf8');

          if (content.includes(pattern)) {

            results += `${file}: ${content.split('\n').filter(l => l.includes(pattern)).join('\n')}\n`;

          }

        }

      });

      alert(results || 'No matches');

    }

    function sortData() {

      const file = prompt('Enter file to sort');

      if (fs.existsSync(file)) {

        let content = fs.readFileSync(file, 'utf8');

        let lines = content.split('\n');

        lines.sort();

        fs.writeFileSync(file, lines.join('\n'));

        alert('Sorted');

      }

    }

    function shareProject() {

      if (currentFile) {

        const content = editor.getValue();

        axios.post('https://console.x.ai/api/upload', { file: path.basename(currentFile), content })

          .then(() => alert('Shared'))

          .catch(() => alert('Failed'));

      }

    }

    function getLangFromExt(ext) {

      const map = {

        '.js': 'javascript',

        '.py': 'python',

        '.html': 'html',

        '.css': 'css',

        '.json': 'json'

      };

      return map[ext] || 'plaintext';

    }

  </script>

</body>

</html>

